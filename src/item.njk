---
layout: layouts/base.njk
---

<main class="pt-16 pb-6 px-4 sm:px-6 max-w-4xl mx-auto min-h-screen">
    <!-- Story Detail -->
    <div id="story-detail" class="mb-12 sm:mb-14">
        <div class="animate-pulse">
            <div
                class="h-8 sm:h-10 skeleton-block rounded w-3/4 mb-4"
            ></div>
            <div
                class="h-4 skeleton-block rounded w-1/4"
            ></div>
        </div>
    </div>

    <!-- Comments Section -->
    <div class="border-t border-default pt-10 sm:pt-12">
        <h2
            class="text-xs sm:text-sm font-headline font-bold tracking-widest text-secondary-muted mb-8 sm:mb-10"
            id="comment-count"
        >
            Comments
        </h2>
        <div id="comments-container" class="space-y-8 sm:space-y-10">
            <!-- Skeleton Loader for Comments -->
            <div id="comments-loader" class="space-y-8 sm:space-y-10 animate-pulse">
                <div class="space-y-3">
                    <div
                        class="h-3 skeleton-block rounded w-24"
                    ></div>
                    <div
                        class="h-4 skeleton-block rounded w-full"
                    ></div>
                    <div
                        class="h-4 skeleton-block rounded w-5/6"
                    ></div>
                </div>
                <div class="space-y-3 ml-4 sm:ml-8">
                    <div
                        class="h-3 skeleton-block rounded w-24"
                    ></div>
                    <div
                        class="h-4 skeleton-block rounded w-full"
                    ></div>
                </div>
                <div class="space-y-3">
                    <div
                        class="h-3 skeleton-block rounded w-24"
                    ></div>
                    <div
                        class="h-4 skeleton-block rounded w-2/3"
                    ></div>
                </div>
            </div>
        </div>
    </div>
</main>

{% include "components/item-logic.njk" %}
