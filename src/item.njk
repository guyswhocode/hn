---
layout: layouts/base.njk
---

<main class="pt-16 pb-4 px-6 max-w-4xl mx-auto min-h-screen">
    <!-- Story Detail -->
    <div id="story-detail" class="mb-10">
        <div class="animate-pulse">
            <div
                class="h-10 bg-surface-container-highest/50 rounded-lg w-3/4 mb-4"
            ></div>
            <div
                class="h-4 bg-surface-container-highest/30 rounded w-1/4"
            ></div>
        </div>
    </div>

    <!-- Comments Section -->
    <div class="border-t border-outline-variant/10 pt-8">
        <h2
            class="text-sm font-headline font-bold tracking-widest text-secondary mb-6"
            id="comment-count"
        >
            Comments
        </h2>
        <div id="comments-container" class="space-y-6">
            <!-- Skeleton Loader for Comments -->
            <div id="comments-loader" class="space-y-8 animate-pulse">
                <div class="space-y-3">
                    <div
                        class="h-3 bg-surface-container-highest/30 rounded w-24"
                    ></div>
                    <div
                        class="h-4 bg-surface-container-highest/50 rounded w-full"
                    ></div>
                    <div
                        class="h-4 bg-surface-container-highest/50 rounded w-5/6"
                    ></div>
                </div>
                <div class="space-y-3 ml-8">
                    <div
                        class="h-3 bg-surface-container-highest/30 rounded w-24"
                    ></div>
                    <div
                        class="h-4 bg-surface-container-highest/50 rounded w-full"
                    ></div>
                </div>
                <div class="space-y-3">
                    <div
                        class="h-3 bg-surface-container-highest/30 rounded w-24"
                    ></div>
                    <div
                        class="h-4 bg-surface-container-highest/50 rounded w-2/3"
                    ></div>
                </div>
            </div>
        </div>
    </div>
</main>

{% include "components/item-logic.njk" %}
