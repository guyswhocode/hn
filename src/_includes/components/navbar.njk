<style>
/* Hide scrollbar for nav links on mobile */
.no-scrollbar::-webkit-scrollbar { display: none; }
.no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

/* Custom green-bordered square checkbox */
.custom-checkbox {
    -webkit-appearance: none;
    appearance: none;
    width: 12px;
    height: 12px;
    border: 1.5px solid var(--accent);
    background: var(--bg-primary);
    cursor: pointer;
    flex-shrink: 0;
    position: relative;
}
.custom-checkbox:checked {
    background: var(--bg-primary);
    border-color: var(--accent);
}
.custom-checkbox:checked::after {
    content: '';
    position: absolute;
    top: 1px;
    left: 3px;
    width: 3px;
    height: 6px;
    border: solid var(--accent);
    border-width: 0 1.5px 1.5px 0;
    transform: rotate(45deg);
}
.custom-checkbox:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
}
</style>
<script>
    function handleThemeToggle() {
        const themeToggle = document.getElementById("theme-toggle");
        if (themeToggle) {
            themeToggle.addEventListener("click", () => {
                const html = document.documentElement;
                const isDark = html.classList.toggle("dark");
                themeToggle.textContent = isDark ? "dark_mode" : "light_mode";
                localStorage.setItem("theme", isDark ? "dark" : "light");
            });

            const savedTheme = localStorage.getItem("theme");
            if (savedTheme === "light") {
                document.documentElement.classList.remove("dark");
                themeToggle.textContent = "light_mode";
            } else {
                document.documentElement.classList.add("dark");
                themeToggle.textContent = "dark_mode";
            }
        }
    }

    handleThemeToggle();

    function handleDensityToggle() {
        const densityToggle = document.getElementById("density-toggle");
        if (densityToggle) {
            densityToggle.addEventListener("click", () => {
                const html = document.documentElement;
                const isCompact = html.classList.toggle("density-compact");
                densityToggle.textContent = isCompact ? "density_medium" : "density_small";
                densityToggle.title = isCompact ? "Switch to comfortable view" : "Switch to compact view";
                localStorage.setItem("density", isCompact ? "compact" : "comfortable");
            });

            const savedDensity = localStorage.getItem("density");
            if (savedDensity === "compact") {
                document.documentElement.classList.add("density-compact");
                densityToggle.textContent = "density_medium";
                densityToggle.title = "Switch to comfortable view";
            } else {
                document.documentElement.classList.remove("density-compact");
                densityToggle.textContent = "density_small";
                densityToggle.title = "Switch to compact view";
            }
        }
    }

    handleDensityToggle();

    /* ── Hacker flicker animation on nav links ── */
    function handleNavHackerEffect() {
        const chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!@#$%^&*()";
        const links = document.querySelectorAll(".nav-links a[data-text]");

        links.forEach(function (link) {
            var timer = null;

            link.addEventListener("mouseenter", function () {
                var self = this;
                var original = self.getAttribute("data-text");
                var len = original.length;
                var frame = 0;
                var totalFrames = 12;

                if (timer) clearInterval(timer);

                timer = setInterval(function () {
                    frame++;

                    // Build scrambled string with progressive reveal
                    var result = "";
                    var revealCount = Math.min(
                        Math.floor((frame / totalFrames) * len),
                        len
                    );

                    for (var i = 0; i < len; i++) {
                        if (i < revealCount) {
                            result += original[i];
                        } else if (frame < totalFrames - 2) {
                            result += chars.charAt(
                                Math.floor(Math.random() * chars.length)
                            );
                        } else {
                            result += original[i];
                        }
                    }

                    self.textContent = result;

                    if (frame >= totalFrames) {
                        clearInterval(timer);
                        timer = null;
                        self.textContent = original;
                    }
                }, 55);
            });

            link.addEventListener("mouseleave", function () {
                if (timer) {
                    clearInterval(timer);
                    timer = null;
                }
                this.textContent = this.getAttribute("data-text");
            });
        });
    }

    handleNavHackerEffect();

    /* ── Search ── */
    const searchBtn = document.getElementById("search-btn");
    const searchModal = document.getElementById("search-modal");
    const searchClose = document.getElementById("search-close");
    const searchInput = document.getElementById("search-input");
    const searchForm = document.getElementById("search-form");

    if (searchBtn && searchModal) {
        searchBtn.addEventListener("click", () => {
            searchModal.classList.remove("hidden");
            setTimeout(() => searchInput?.focus(), 100);
        });

        if (searchClose) {
            searchClose.addEventListener("click", () => {
                searchModal.classList.add("hidden");
            });
        }

        searchModal.addEventListener("click", (e) => {
            if (e.target === searchModal) {
                searchModal.classList.add("hidden");
            }
        });

        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape" && !searchModal.classList.contains("hidden")) {
                searchModal.classList.add("hidden");
            }
        });

        if (searchForm) {
            searchForm.addEventListener("submit", (e) => {
                e.preventDefault();
                const query = searchInput.value.trim();
                if (query) {
                    // Collect selected tags
                    var tagCheckboxes = searchForm.querySelectorAll('input[name="tag"]:checked');
                    var tags = [];
                    tagCheckboxes.forEach(function (cb) { tags.push(cb.value); });
                    // Compute relative path to search page from current URL depth
                    var pathParts = window.location.pathname.split('/').filter(Boolean);
                    var depth = Math.max(0, pathParts.length - 1);
                    var prefix = depth === 0 ? './' : '../'.repeat(depth);
                    var url = prefix + 'search.html?q=' + encodeURIComponent(query);
                    if (tags.length > 0) url += '&tags=' + tags.join(',');
                    window.location.href = url;
                }
            });
        }

        // Mutual exclusion: comment vs story/show_hn/ask_hn
        var tagCheckboxes = searchForm.querySelectorAll('input[name="tag"]');
        tagCheckboxes.forEach(function (cb) {
            cb.addEventListener("change", function () {
                if (this.value === "comment" && this.checked) {
                    tagCheckboxes.forEach(function (other) {
                        if (other.value !== "comment") other.checked = false;
                    });
                } else if (this.value !== "comment" && this.checked) {
                    tagCheckboxes.forEach(function (other) {
                        if (other.value === "comment") other.checked = false;
                    });
                }
            });
        });
    }
</script>
