            </a>
            <div class="nav-links flex items-center gap-3 sm:gap-6 overflow-x-auto no-scrollbar">
                <a
                    class="text-secondary-muted font-bold tracking-tight text-[0.6rem] sm:text-xs hover:text-accent font-headline transition-colors whitespace-nowrap"
                    href="{{ base }}?type=new"
                    data-type="new"
                    >new</a
                >
                <a
                    class="text-secondary-muted font-bold tracking-tight text-[0.6rem] sm:text-xs hover:text-accent font-headline transition-colors whitespace-nowrap"
                    href="{{ base }}?type=ask"
                    data-type="ask"
                    >ask</a
                >
                <a
                    class="text-secondary-muted font-bold tracking-tight text-[0.6rem] sm:text-xs hover:text-accent font-headline transition-colors whitespace-nowrap"
                    href="{{ base }}?type=show"
                    data-type="show"
                    >show</a
                >
                <a
                    class="text-secondary-muted font-bold tracking-tight text-[0.6rem] sm:text-xs hover:text-accent font-headline transition-colors whitespace-nowrap"
