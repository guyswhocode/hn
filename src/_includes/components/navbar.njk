        </div>
        <div class="flex items-center gap-2 sm:gap-4 flex-shrink-0">
            <button
                id="density-toggle"
                class="material-symbols-outlined cursor-pointer text-secondary-muted hover:text-accent transition-colors !text-[14px] sm:!text-lg"
                title="Toggle compact view"
            >
                density_small
            </button>
            <a
                href="{{ base }}bookmark"
                class="material-symbols-outlined cursor-pointer text-secondary-muted hover:text-accent transition-colors !text-[14px] sm:!text-lg"
                title="Bookmarks"
            >
                bookmark
            </a>
            <button
                id="theme-toggle"
                class="material-symbols-outlined cursor-pointer text-secondary-muted hover:text-accent transition-colors !text-[14px] sm:!text-lg"
