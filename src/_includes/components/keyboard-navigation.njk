<!-- Keyboard Shortcuts Modal -->
<div
    id="shortcuts-modal"
    class="hidden fixed inset-0 z-[100] flex items-center justify-center px-4 sm:px-6"
    style="background-color: rgba(0,0,0,0.6); backdrop-filter: blur(4px);"
>
    <div
        class="bg-surface w-full max-w-md rounded border-accent p-6 sm:p-8"
        style="border: 1px solid var(--accent-border);"
    >
        <div class="flex justify-between items-center mb-6 sm:mb-8">
            <h3
                class="text-lg sm:text-xl font-headline font-bold uppercase tracking-tighter text-accent terminal-cursor"
            >
                Shortcuts
            </h3>
            <button
                id="close-shortcuts"
                class="material-symbols-outlined cursor-pointer text-secondary-muted hover:text-accent transition-colors"
            >
                close
            </button>
        </div>
        <div class="space-y-4 sm:space-y-5">
            <div class="flex justify-between items-center">
                <span
                    class="text-[10px] sm:text-xs font-semibold text-secondary-muted uppercase tracking-widest"
                    >Navigation</span
                >
                <div class="flex gap-2">
                    <kbd>J</kbd>
                    <kbd>K</kbd>
                </div>
            </div>
            <div class="flex justify-between items-center">
                <span
                    class="text-[10px] sm:text-xs font-semibold text-secondary-muted uppercase tracking-widest"
                    >Open Story</span
                >
                <div class="flex gap-2">
                    <kbd>Enter</kbd>
                    <kbd>O</kbd>
                </div>
            </div>
            <div class="flex justify-between items-center">
                <span
                    class="text-[10px] sm:text-xs font-semibold text-secondary-muted uppercase tracking-widest"
                    >Open Comments</span
                >
                <kbd>C</kbd>
            </div>
            <div class="flex justify-between items-center">
                <span
                    class="text-[10px] sm:text-xs font-semibold text-secondary-muted uppercase tracking-widest"
                    >Author Profile</span
                >
                <kbd>U</kbd>
            </div>
            <div class="flex justify-between items-center">
                <span
                    class="text-[10px] sm:text-xs font-semibold text-secondary-muted uppercase tracking-widest"
                    >New Tab</span
                >
                <kbd>Shift + Enter</kbd>
            </div>
            <div class="flex justify-between items-center">
                <span
                    class="text-[10px] sm:text-xs font-semibold text-secondary-muted uppercase tracking-widest"
                    >Bookmarks</span
                >
                <kbd>B</kbd>
            </div>
        </div>
    </div>
</div>
<!-- Floating Hints Button -->
<button
    id="help-btn"
    class="fixed bottom-4 sm:bottom-6 right-4 sm:right-6 material-symbols-outlined cursor-pointer text-secondary-muted hover:text-accent transition-colors text-lg sm:text-xl z-50"
>
    help
</button>

<script>
    const shortcutsModal = document.getElementById("shortcuts-modal");
    const helpBtn = document.getElementById("help-btn");
    const closeShortcuts = document.getElementById("close-shortcuts");

    if (helpBtn) {
        helpBtn.addEventListener("click", () => {
            shortcutsModal.classList.remove("hidden");
        });
    }

    if (closeShortcuts) {
        closeShortcuts.addEventListener("click", () => {
            shortcutsModal.classList.add("hidden");
        });
    }

    if (shortcutsModal) {
        shortcutsModal.addEventListener("click", (e) => {
            if (e.target === shortcutsModal) {
                shortcutsModal.classList.add("hidden");
            }
        });
    }

    let selectedStoryIndex = -1;

    function updateActiveStory(index) {
        const stories = feedContainer.querySelectorAll("article");
        if (stories.length === 0) return;

        stories.forEach((s) => s.classList.remove("active-story"));

        selectedStoryIndex = Math.max(0, Math.min(index, stories.length - 1));

        const activeStory = stories[selectedStoryIndex];

        if (activeStory) {
            activeStory.classList.add("active-story");
            activeStory.scrollIntoView({
                behavior: "smooth",
                block: "nearest",
            });
        }
    }

    document.addEventListener("keydown", (e) => {
        if (e.target.tagName === "INPUT" || e.target.tagName === "TEXTAREA")
            return;

        const stories = feedContainer.querySelectorAll("article");

        if (stories.length === 0) return;

        switch (e.key.toLowerCase()) {
            case "j":
                updateActiveStory(selectedStoryIndex + 1);
                break;
            case "k": {
                updateActiveStory(selectedStoryIndex - 1);
                break;
            }

            case "enter":
            case "o":
                if (selectedStoryIndex !== -1) {
                    const link = stories[selectedStoryIndex].querySelector("a");
                    if (link) {
                        if (e.shiftKey) {
                            window.open(link.href, "_blank");
                        } else {
                            link.click();
                        }
                    }
                }
                break;
            case "c":
                if (selectedStoryIndex !== -1) {
                    const commentsLink = stories[
                        selectedStoryIndex
                    ].querySelector('a[href^="item/index.html"]');
                    if (commentsLink) commentsLink.click();
                }
                break;
            case "u":
                if (selectedStoryIndex !== -1) {
                    const userLink =
                        stories[selectedStoryIndex].querySelector(
                            'a[href^="user"]',
                        );
                    if (userLink) userLink.click();
                }
                break;
            case "b":
                window.location.href = "bookmark/index.html";
                break;
            case "?":
                if (shortcutsModal) shortcutsModal.classList.toggle("hidden");
                break;
            case "escape":
                if (shortcutsModal) shortcutsModal.classList.add("hidden");
                break;
        }
    });
</script>
