<script>
    const bookmarkContainer = document.getElementById("bookmark-container");

    function createStoryElement(story, index) {
        const formattedIndex = index < 9 ? `0${index + 1}` : index + 1;
        const isStoryBookmarked = isBookmarked(story.id);

        const article = document.createElement("article");
        article.className = "group relative flex items-start py-5 sm:py-6 px-2 rounded transition-colors";
        article.id = `bookmark-${story.id}`;

        article.innerHTML = `
            <div class="flex flex-col items-center w-8 mr-4 pt-1 story-index flex-shrink-0">
                <span class="text-base font-headline font-bold text-accent transition-colors">${formattedIndex}</span>
            </div>
            <div class="flex-1 min-w-0">
                <div class="flex flex-wrap items-baseline gap-1.5 mb-1.5">
                    <a class="story-title text-[15px] font-medium leading-snug hover:text-accent transition-colors"
                    href="../item/index.html?id=${story.id}">
                        ${story.title}
                    </a>
                    <span class="text-[10px] text-muted font-label tracking-wide">${getDomain(story.url)}</span>
                </div>
                <div class="story-meta flex flex-wrap items-center gap-x-5 gap-y-1 text-[0.65rem] text-secondary-muted font-label font-semibold tracking-wider">
                    <span class="flex items-center gap-1">
                    <span class="material-symbols-outlined !text-[12px]">change_history</span>
                    ${story.score || 0}</span>
                    <span class="flex items-center gap-1">
                        <span class="material-symbols-outlined !text-[12px]">person</span>
                        <a class="hover:text-accent transition-colors underline decoration-accent underline-offset-2"
                        href="../user/index.html?id=${story.by}">${story.by}</a>
                    </span>
                    <span class="flex items-center gap-1">
                        <span class="material-symbols-outlined !text-[12px]">schedule</span>
                        ${timeAgo(story.time)}
                    </span>
                    <a class="flex items-center gap-1 hover:text-accent transition-colors"
                    href="../item/index.html?id=${story.id}">
                        <span class="material-symbols-outlined !text-[12px]">chat</span>
                        ${story.descendants || 0}
                    </a>
                    <button class="bookmark-btn cursor-pointer flex items-center gap-1 hover:text-accent transition-colors" data-id="${story.id}">
                        <span class="material-symbols-outlined !text-[14px] ${isStoryBookmarked ? "text-accent material-symbols-filled" : ""}">
                            bookmark
                        </span>
                    </button>
                </div>
            </div>
        `;
        return article;
    }

    async function loadBookmarks() {
        const bookmarks = getBookmarks();

        if (bookmarks.length === 0) {
            bookmarkContainer.innerHTML = '<div class="py-10 text-center text-secondary-muted">No bookmarks found.</div>';
            return;
        }

        const storyPromises = bookmarks.map(id => fetchItem(id));
        const stories = await Promise.all(storyPromises);

        bookmarkContainer.innerHTML = "";
        stories.forEach((story, index) => {
            if (story) {
                bookmarkContainer.appendChild(createStoryElement(story, index));
            }
        });
    }

    bookmarkContainer.addEventListener("click", (e) => {
        const bookmarkBtn = e.target.closest(".bookmark-btn");
        if (bookmarkBtn) {
            const id = parseInt(bookmarkBtn.dataset.id);
            const added = toggleBookmark(id);

            if (!added) {
                const article = document.getElementById(`bookmark-${id}`);
                if (article) {
                    article.remove();
                    if (bookmarkContainer.children.length === 0) {
                        bookmarkContainer.innerHTML = '<div class="py-10 text-center text-secondary-muted">No bookmarks found.</div>';
                    }
                }
            }
        }
    });

    loadBookmarks();

    // ── Status Modal ──

    const modal = document.getElementById("status-modal");
    const modalIcon = document.getElementById("modal-icon");
    const modalTitle = document.getElementById("modal-title");
    const modalMessage = document.getElementById("modal-message");
    const modalClose = document.getElementById("modal-close");

    function showModal(title, icon, message) {
        modalTitle.textContent = title;
        modalIcon.textContent = icon;
        modalMessage.innerHTML = message;
        modal.classList.remove("hidden");
    }

    modalClose.addEventListener("click", () => modal.classList.add("hidden"));
    modal.addEventListener("click", (e) => {
        if (e.target === modal) modal.classList.add("hidden");
    });

    // ── Export/Import Bookmarks ──

    document.getElementById("export-bookmarks").addEventListener("click", () => {
        const bookmarks = getBookmarks();
        if (bookmarks.length === 0) {
            showModal("Export", "info", "No bookmarks to export.");
            return;
        }
        const content = bookmarks.join("\n");
        const blob = new Blob([content], { type: "text/plain" });
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url;
        a.download = "hn-bookmarks.txt";
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
        showModal("Export", "check_circle", `Exported <strong>${bookmarks.length}</strong> bookmark${bookmarks.length !== 1 ? "s" : ""}.`);
    });

    const importBtn = document.getElementById("import-bookmarks");
    const fileInput = document.getElementById("import-file-input");

    importBtn.addEventListener("click", () => fileInput.click());

    fileInput.addEventListener("change", async (e) => {
        const file = e.target.files[0];
        if (!file) return;

        const text = await file.text();
        const ids = text
            .split("\n")
            .map(line => line.trim())
            .filter(line => /^\d+$/.test(line))
            .map(Number);

        if (ids.length === 0) {
            showModal("Import", "warning", "No valid bookmark IDs found in the file.<br>Each line should contain a numeric ID.");
            fileInput.value = "";
            return;
        }

        const existing = getBookmarks();
        const existingSet = new Set(existing);
        const newIds = ids.filter(id => !existingSet.has(id));
        const merged = [...existingSet, ...newIds];
        localStorage.setItem("bookmarks", JSON.stringify(merged));

        fileInput.value = "";
        loadBookmarks();

        if (newIds.length === 0) {
            showModal("Import", "bookmark", `All <strong>${ids.length}</strong> ID${ids.length !== 1 ? "s" : ""} were already bookmarked.`);
        } else {
            showModal("Import", "check_circle", `Imported <strong>${newIds.length}</strong> new bookmark${newIds.length !== 1 ? "s" : ""}${ids.length !== newIds.length ? ` (${ids.length - newIds.length} already existed)` : ""}.`);
        }
    });
</script>
