<script>
    const ITEMS_PER_PAGE = 20;
    const TYPE_MAP = {
        new: "newstories",
        top: "topstories",
        ask: "askstories",
        show: "showstories",
        jobs: "jobstories",
    };

    let currentStoryIds = [];
    let currentPage = 0;
    let currentType = TYPE_MAP["top"];

    const feedContainer = document.getElementById("feed-container");
    const loadMoreBtn = document.getElementById("load-more-btn");
    const navLinks = document.querySelectorAll("nav a[data-type]");

    async function fetchStoryIds(type) {
        const endpoint = TYPE_MAP[type] || TYPE_MAP["top"];
        const response = await fetch(`${API_BASE_URL}/${endpoint}.json`);
        return await response.json();
    }

    function createStoryElement(story, index) {
        const absoluteIndex = currentPage * ITEMS_PER_PAGE + index + 1;
        const formattedIndex = absoluteIndex < 10 ? `0${absoluteIndex}` : absoluteIndex;
        const isStoryBookmarked = isBookmarked(story.id);

        const article = document.createElement("article");
        article.className = "group relative flex items-start py-5 sm:py-6 px-2 rounded transition-colors";

        article.innerHTML = `
    <div class="flex flex-col items-center w-8 mr-4 pt-1 story-index flex-shrink-0">
        <span class="text-base font-headline font-bold text-accent transition-colors">${formattedIndex}</span>
    </div>
    <div class="flex-1 min-w-0">
        <div class="flex flex-wrap items-baseline gap-1.5 mb-1.5">
            <a class="story-title text-[15px] font-medium leading-snug hover:text-accent transition-colors"
            href="${story.url || `item/index.html?id=${story.id}`}" ${story.url ? 'target="_blank"' : ""}
            data-text="${story.title.replace(/"/g, '&quot;')}">
                ${story.title}
            </a>
            <span class="text-[10px] text-muted font-label tracking-wide">${getDomain(story.url)}</span>
        </div>
        <div class="story-meta flex flex-wrap items-center gap-x-5 gap-y-1 text-[0.65rem] text-secondary-muted font-label font-semibold tracking-wider">
            <span class="flex items-center gap-1">
            <span class="material-symbols-outlined !text-[12px]">change_history</span>
            ${story.score || 0}</span>
            <span class="flex items-center gap-1">
                <span class="material-symbols-outlined !text-[12px]">person</span>
                <a class="hover:text-accent transition-colors underline decoration-accent underline-offset-2"
                href="user/index.html?id=${story.by}">${story.by}</a>
            </span>
            <span class="flex items-center gap-1">
                <span class="material-symbols-outlined !text-[12px]">schedule</span>
                ${timeAgo(story.time)}
            </span>
            <a class="flex items-center gap-1 hover:text-accent transition-colors"
            href="item/index.html?id=${story.id}">
                <span class="material-symbols-outlined !text-[12px]">chat</span>
                ${story.descendants || 0}
            </a>
            <button class="bookmark-btn cursor-pointer flex items-center gap-1 hover:text-accent transition-colors" data-id="${story.id}">
                <span class="material-symbols-outlined !text-[14px] ${isStoryBookmarked ? "text-accent material-symbols-filled" : ""}">
                    bookmark
                </span>
            </button>
        </div>
    </div>
`;
        return article;
    }

    feedContainer.addEventListener("click", (e) => {
        const bookmarkBtn = e.target.closest(".bookmark-btn");
        if (bookmarkBtn) {
            const id = parseInt(bookmarkBtn.dataset.id);
            const added = toggleBookmark(id);
            const icon = bookmarkBtn.querySelector(".material-symbols-outlined");
            if (added) {
                icon.classList.add("material-symbols-filled", "text-accent");
            } else {
                icon.classList.remove("material-symbols-filled", "text-accent");
            }
        }
    });

    async function loadStories(append = false) {
        if (!append) {
            selectedStoryIndex = -1;
            let placeholderItem = `<div class="animate-pulse flex items-start px-2 py-5 sm:py-6">
        <div class="w-8 h-8 skeleton-block rounded mr-4"></div>
        <div class="flex-1 space-y-3">
            <div class="h-4 skeleton-block rounded w-4/5"></div>
            <div class="h-3 skeleton-block rounded w-1/4"></div>
        </div>
    </div>`;
            feedContainer.innerHTML = `
    <div id="feed-loader" class="space-y-5 pt-4">
        ${placeholderItem.repeat(10)}
    </div>
    `;
            currentPage = 0;
            currentStoryIds = await fetchStoryIds(currentType);
        } else {
            loadMoreBtn.disabled = true;
            loadMoreBtn.innerHTML = `<span class="flex items-center gap-1.5">
        <span class="material-symbols-outlined animate-spin !text-[11px]">progress_activity</span>
        Loading
    </span>`;
        }

        const start = currentPage * ITEMS_PER_PAGE;
        const end = start + ITEMS_PER_PAGE;
        const pageIds = currentStoryIds.slice(start, end);

        if (pageIds.length === 0) {
            if (!append)
                feedContainer.innerHTML =
                    '<div class="py-10 text-center text-secondary-muted">No stories found.</div>';
            loadMoreBtn.classList.add("hidden");
            return;
        }

        const storyPromises = pageIds.map((id) => fetchItem(id));
        const stories = await Promise.all(storyPromises);

        const loader = document.getElementById("feed-loader");
        if (loader && !append) feedContainer.innerHTML = "";

        var hackableTitles = [];
        stories.forEach((story, index) => {
            if (story) {
                var el = createStoryElement(story, index);
                feedContainer.appendChild(el);
                var titleEl = el.querySelector('.story-title');
                if (titleEl) hackableTitles.push(titleEl);
            }
        });

        // Kick off hacker reveal animation for each new title
        hackableTitles.forEach(function (titleEl) {
            hackerRevealElement(titleEl);
        });

        currentPage++;

        if (append) {
            loadMoreBtn.disabled = false;
            loadMoreBtn.innerHTML = "Show More";
        }

        if (currentPage * ITEMS_PER_PAGE >= currentStoryIds.length) {
            loadMoreBtn.classList.add("hidden");
        } else {
            loadMoreBtn.classList.remove("hidden");
        }
    }

    if (loadMoreBtn)
        loadMoreBtn.addEventListener("click", () => loadStories(true));

    function init() {
        const urlParams = new URLSearchParams(window.location.search);
        const typeParam = urlParams.get("type");

        if (typeParam && TYPE_MAP[typeParam]) {
            currentType = typeParam;
            const activeLink = document.querySelector(
                `nav a[data-type="${typeParam}"]`,
            );
            if (activeLink) {
                let activeLinkClasses = [
                    "text-accent",
                    "border-b-2",
                    "border-accent-strong",
                    "pb-0.5",
                ];
                let inactiveLinkClasses = [
                    "text-secondary-muted",
                ];
                navLinks.forEach((l) => {
                    l.classList.remove(...activeLinkClasses);
                    l.classList.add(...inactiveLinkClasses);
                });
                activeLink.classList.add(...activeLinkClasses);
                activeLink.classList.remove(...inactiveLinkClasses);
            }
        }

        loadStories();
    }
    init();
</script>
