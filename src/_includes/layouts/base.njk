{% set base = '../' if '/user/' in page.url or '/item/' in page.url or '/bookmark/' in page.url else './' %}
<html class="dark" lang="en">
    <head>
        <meta charset="utf-8" />
        <meta content="width=device-width, initial-scale=1.0" name="viewport" />
        <link
            rel="icon"
            type="image/x-icon"
            href="{{ base }}assets/images/favicon.ico"
        />
        <link
            rel="apple-touch-icon"
            href="{{ base }}assets/images/apple-touch-icon.png"
        />
        <meta property="og:title" content="HN" />
        <meta
            property="og:description"
            content="Minimal web client for Hacker News content."
        />
        <meta
            property="og:image"
            content="{{ base }}assets/images/og-image.png"
        />
        <meta property="og:type" content="website" />
        <title>HN</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500;600;700&amp;display=swap"
            rel="stylesheet"
            media="print"
            onload="this.media='all'"
        />
        <link
            href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
            rel="stylesheet"
            media="print"
            onload="this.media='all'"
        />
        <style>
            {% inlineCss "assets/css/style.css" %}
        </style>
    </head>
    <body
        class="font-body"
        style="background-color: var(--bg-primary); color: var(--text-primary);"
    >
        {% include "components/navbar.njk" %}
        <!-- Terminal status bar -->
        <div class="fixed top-0 left-0 w-full h-[1px] z-[60]" style="background-color: var(--accent-border);"></div>
        {% include "components/shared-logic.njk" %}
        {{ content | safe }}
        {% include "components/footer.njk" %}
    </body>
</html>
