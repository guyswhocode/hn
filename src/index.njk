---
layout: layouts/base.njk
---

<!-- Main Content Canvas -->
<main class="pt-16 pb-6 px-4 sm:px-6 max-w-4xl mx-auto min-h-screen">
    <!-- Feed Items -->
    <div id="feed-container" class="divide-default">
        <!-- Skeleton Loader -->
        <div id="feed-loader" class="space-y-5 pt-4">
            <div class="animate-pulse flex items-start px-2 py-5">
                <div
                    class="w-8 h-8 skeleton-block rounded mr-4"
                ></div>
                <div class="flex-1 space-y-3">
                    <div
                        class="h-4 skeleton-block rounded w-3/4"
                    ></div>
                    <div
                        class="h-3 skeleton-block rounded w-1/2"
                    ></div>
                </div>
            </div>
        </div>
    </div>
    <div class="mt-10 sm:mt-12 text-center">
        <button
            id="load-more-btn"
            class="hidden inline-flex items-center justify-center px-5 sm:px-6 py-2.5 sm:py-3 btn-accent font-headline font-bold uppercase tracking-widest text-[9px] sm:text-[11px]"
        >
            Show More
        </button>
    </div>
</main>

{% include "components/load-stories-logic.njk" %} {% include
"components/keyboard-navigation.njk" %}
