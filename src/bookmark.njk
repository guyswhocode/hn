---
layout: layouts/base.njk
permalink: /bookmark/index.html
---

<main class="pt-16 pb-6 px-4 sm:px-6 max-w-4xl mx-auto min-h-screen">
    <header class="pt-2 sm:pt-4 mb-6 sm:mb-8 flex flex-wrap items-center justify-between gap-3">
        <h1 class="text-lg sm:text-xl font-headline font-bold uppercase tracking-widest text-accent">Bookmarks</h1>
        <div class="flex items-center gap-2">
            <button id="export-bookmarks" class="btn-accent text-[9px] sm:text-[10px] font-headline font-bold uppercase tracking-widest px-3 py-1.5 rounded">
                Export
            </button>
            <button id="import-bookmarks" class="btn-accent text-[9px] sm:text-[10px] font-headline font-bold uppercase tracking-widest px-3 py-1.5 rounded">
                Import
            </button>
            <input id="import-file-input" type="file" accept=".txt" class="hidden">
        </div>
    </header>
    <!-- Feed Items -->
    <div id="bookmark-container" class="divide-default">
        <!-- Loader -->
        <div id="bookmark-loader" class="space-y-5 pt-4">
            <div class="animate-pulse flex items-start px-2 py-5">
                <div class="w-8 h-8 skeleton-block rounded mr-4"></div>
                <div class="flex-1 space-y-3">
                    <div class="h-4 skeleton-block rounded w-3/4"></div>
                    <div class="h-3 skeleton-block rounded w-1/2"></div>
                </div>
            </div>
        </div>
    </div>
</main>

{% include "components/bookmark-page-logic.njk" %}
