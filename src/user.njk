---
layout: layouts/base.njk
---

<!-- Main Content Canvas -->
<main class="pt-16 pb-6 px-4 sm:px-6 max-w-4xl mx-auto min-h-screen">
    <!-- User Header -->
    <div id="user-header" class="pt-3 sm:pt-4 mb-12 sm:mb-16">
        <div class="animate-pulse">
            <div
                class="h-8 sm:h-10 skeleton-block rounded w-1/2 mb-4"
            ></div>
            <div
                class="h-4 skeleton-block rounded w-1/4 mb-2"
            ></div>
            <div
                class="h-4 skeleton-block rounded w-1/3"
            ></div>
        </div>
    </div>

    <!-- User Submissions -->
    <div>
        <h2
            class="text-xs sm:text-sm font-headline font-bold uppercase tracking-widest text-secondary-muted mb-8 sm:mb-10 border-b border-default pb-3"
        >
            Submissions
        </h2>
        <div
            id="submissions-container"
            class="divide-default"
        >
            <div id="submissions-loader" class="space-y-5 pt-4 animate-pulse">
                <div
                    class="h-14 sm:h-16 skeleton-block rounded w-full"
                ></div>
                <div
                    class="h-14 sm:h-16 skeleton-block rounded w-full"
                ></div>
                <div
                    class="h-14 sm:h-16 skeleton-block rounded w-full"
                ></div>
            </div>
        </div>
        <div class="mt-10 sm:mt-12 text-center">
            <button
                id="load-more-submissions"
                class="hidden inline-flex items-center justify-center px-5 sm:px-6 py-2.5 sm:py-3 btn-accent font-headline font-bold uppercase tracking-widest text-[9px] sm:text-[11px]"
            >
                Show More
            </button>
        </div>
    </div>
</main>

{% include "components/user-logic.njk" %}
