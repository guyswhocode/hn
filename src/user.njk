---
layout: layouts/base.njk
---

<!-- Main Content Canvas -->
<main class="pt-16 pb-4 px-6 max-w-4xl mx-auto min-h-screen">
    <!-- User Header -->
    <div id="user-header" class="mb-12">
        <div class="animate-pulse">
            <div
                class="h-10 bg-surface-container-highest/50 rounded-lg w-1/2 mb-4"
            ></div>
            <div
                class="h-4 bg-surface-container-highest/30 rounded w-1/4 mb-2"
            ></div>
            <div
                class="h-4 bg-surface-container-highest/30 rounded w-1/3"
            ></div>
        </div>
    </div>

    <!-- User Submissions -->
    <div>
        <h2
            class="text-sm font-headline font-bold uppercase tracking-widest text-secondary mb-6 border-b border-outline-variant/10 pb-2"
        >
            Submissions
        </h2>
        <div
            id="submissions-container"
            class="divide-y divide-outline-variant/10"
        >
            <div id="submissions-loader" class="space-y-4 pt-4 animate-pulse">
                <div
                    class="h-16 bg-surface-container-highest/20 rounded-lg w-full"
                ></div>
                <div
                    class="h-16 bg-surface-container-highest/20 rounded-lg w-full"
                ></div>
                <div
                    class="h-16 bg-surface-container-highest/20 rounded-lg w-full"
                ></div>
            </div>
        </div>
        <div class="mt-8 text-center">
            <button
                id="load-more-submissions"
                class="hidden inline-flex items-center justify-center px-6 py-2.5 bg-surface-container-high dark:bg-white/10 rounded-lg font-headline font-bold uppercase tracking-widest text-[10px] text-primary hover:bg-primary-container hover:text-on-primary disabled:opacity-50 disabled:cursor-not-allowed transition-all duration-300"
            >
                Show More
            </button>
        </div>
    </div>
</main>

{% include "components/user-logic.njk" %}
